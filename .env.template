# URL to your Ollama instance. If running strictly locally on host, you might use http://host.docker.internal:11434 or local IP.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# The Ollama model to use for analysis 
OLLAMA_MODEL=gemma4:e4b

# Comma-separated list of keywords that will trigger an error snapshot
ERROR_KEYWORDS=ERROR,FATAL,Exception,CRITICAL

# Container Names to globally ignore (comma separated, optional)
IGNORE_CONTAINERS=log2localllm,dozzle,ollama
